// ============================================================================
// AssetFlow — Prisma Schema
// Generated to match: hld.md, lld.md, architecture.md, business-invariants.md
//
// 16 core models + Better Auth support tables (Session, Account, Verification)
//   Identity:      User, Session, Account, Verification
//   Organization:  Department, AssetCategory
//   Asset core:    Asset
//   Allocation:    Allocation, TransferRequest
//   Booking:       Booking
//   Maintenance:   MaintenanceRequest
//   Audit:         AuditCycle, AuditCycleAuditor, AuditItem
//   Notification:  Notification
//   Activity:      ActivityLog
//
// IMPORTANT — constraints Prisma cannot express natively must be added via
// hand-written SQL migrations AFTER `prisma migrate dev`. Search this file
// for "RAW MIGRATION REQUIRED" comments. See lld.md §2.3 for exact SQL.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------------

enum UserRole {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

enum HolderType {
  EMPLOYEE
  DEPARTMENT
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum NotificationType {
  ASSET_ASSIGNED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_APPROVED
  OVERDUE_RETURN_ALERT
  AUDIT_DISCREPANCY_FLAGGED
}

// ----------------------------------------------------------------------------
// IDENTITY — Better Auth + business fields
// ----------------------------------------------------------------------------

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  role          UserRole   @default(EMPLOYEE)
  status        UserStatus @default(ACTIVE)

  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])

  headedDepartment Department? @relation("DepartmentHead")

  sessions Session[]
  accounts Account[]

  allocationsHeld             Allocation[]         @relation("AllocationHolder")
  bookingsCreated             Booking[]
  maintenanceRequestsRaised   MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceRequestsApproved MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  transfersRequestedFrom        TransferRequest[]    @relation("TransferFromEmployee")
  transfersRequestedTo        TransferRequest[]    @relation("TransferToEmployee")
  transfersApproved           TransferRequest[]    @relation("TransferApprovedBy")
  auditCyclesCreated          AuditCycle[]         @relation("AuditCreatedBy")
  auditCycleAssignments       AuditCycleAuditor[]
  auditItemsVerified          AuditItem[]          @relation("AuditVerifiedBy")
  notifications               Notification[]
  activityLogs                ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([role])
  @@index([status])
}

// Better Auth standard tables — do not add business logic here.

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

// Backs both email verification and forgot-password (15-min, one-time, hashed).
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

// ----------------------------------------------------------------------------
// ORGANIZATION
// ----------------------------------------------------------------------------

model Department {
  id     String           @id @default(cuid())
  name   String           @unique
  status DepartmentStatus @default(ACTIVE)

  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")

  headId String? @unique
  head   User?   @relation("DepartmentHead", fields: [headId], references: [id])

  members     User[]       @relation("DepartmentMembers")
  assets      Asset[]
  allocations Allocation[] @relation("AllocationDepartmentHolder")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([parentId])
}

model AssetCategory {
  id           String  @id @default(cuid())
  name         String  @unique
  customFields Json?
  assets       Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// ASSET CORE
// ----------------------------------------------------------------------------

model Asset {
  id              String      @id @default(cuid())
  assetTag        String      @unique // format AF-000001, from asset_tag_seq — immutable
  serialNumber    String      @unique
  name            String
  status          AssetStatus @default(AVAILABLE)
  isBookable      Boolean     @default(false)
  location        String?
  acquisitionCost Decimal     @default(0) @db.Decimal(12, 2)
  acquisitionDate DateTime?
  imageUrl        String?

  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RAW MIGRATION REQUIRED: cost_non_negative CHECK ("acquisitionCost" >= 0)
  @@index([assetTag])
  @@index([serialNumber])
  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([location])
  @@index([name])
}

// ----------------------------------------------------------------------------
// ALLOCATION & TRANSFER
// ----------------------------------------------------------------------------

model Allocation {
  id     String           @id @default(cuid())
  status AllocationStatus @default(ACTIVE)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  holderType         HolderType
  holderEmployeeId   String?
  holderEmployee     User?       @relation("AllocationHolder", fields: [holderEmployeeId], references: [id])
  holderDepartmentId String?
  holderDepartment   Department? @relation("AllocationDepartmentHolder", fields: [holderDepartmentId], references: [id])

  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  conditionNotes     String?

  transferRequests TransferRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RAW MIGRATION REQUIRED (partial unique index):
  //   CREATE UNIQUE INDEX one_active_allocation_per_asset
  //     ON "Allocation" ("assetId") WHERE status = 'ACTIVE';
  // RAW MIGRATION REQUIRED (check):
  //   ALTER TABLE "Allocation" ADD CONSTRAINT return_after_allocate
  //     CHECK ("actualReturnDate" IS NULL OR "actualReturnDate" >= "allocatedAt");
  @@index([assetId])
  @@index([holderEmployeeId])
  @@index([holderDepartmentId])
  @@index([status])
}

model TransferRequest {
  id     String         @id @default(cuid())
  status TransferStatus @default(REQUESTED)

  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id])

  fromEmployeeId String
  fromEmployee   User   @relation("TransferFromEmployee", fields: [fromEmployeeId], references: [id])

  toEmployeeId String
  toEmployee   User   @relation("TransferToEmployee", fields: [toEmployeeId], references: [id])

  reason String? // shown as "Reason" textarea on Screen 5 (Allocation & Transfer)

  approvedById String?
  approvedBy   User?   @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([allocationId])
  @@index([status])
  @@index([approvedById])
}

// ----------------------------------------------------------------------------
// BOOKING
// ----------------------------------------------------------------------------

model Booking {
  id     String        @id @default(cuid())
  status BookingStatus @default(UPCOMING)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  bookedById String
  bookedBy   User   @relation(fields: [bookedById], references: [id])

  startTime DateTime
  endTime   DateTime
  purpose   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RAW MIGRATION REQUIRED (btree_gist + EXCLUDE, P1-only migration):
  //   CREATE EXTENSION IF NOT EXISTS btree_gist;
  //   ALTER TABLE "Booking" ADD CONSTRAINT no_overlapping_bookings
  //     EXCLUDE USING GIST ("assetId" WITH =, tstzrange("startTime","endTime",'[)') WITH &&)
  //     WHERE (status IN ('UPCOMING','ONGOING'));
  // RAW MIGRATION REQUIRED (check):
  //   ALTER TABLE "Booking" ADD CONSTRAINT booking_end_after_start CHECK ("endTime" > "startTime");
  @@index([assetId])
  @@index([status])
  @@index([startTime, endTime])
}

// ----------------------------------------------------------------------------
// MAINTENANCE
// ----------------------------------------------------------------------------

model MaintenanceRequest {
  id          String              @id @default(cuid())
  status      MaintenanceStatus   @default(PENDING)
  priority    MaintenancePriority @default(MEDIUM)
  description String

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  raisedById String
  raisedBy   User   @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])

  approvedById String?
  approvedBy   User?   @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])

  technicianName String?
  approvedAt     DateTime?
  resolvedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RAW MIGRATION REQUIRED (partial unique index):
  //   CREATE UNIQUE INDEX one_active_maintenance_per_asset
  //     ON "MaintenanceRequest" ("assetId") WHERE status NOT IN ('REJECTED','RESOLVED');
  @@index([assetId])
  @@index([status])
}

// ----------------------------------------------------------------------------
// AUDIT
// ----------------------------------------------------------------------------

model AuditCycle {
  id     String           @id @default(cuid())
  name   String
  status AuditCycleStatus @default(OPEN)

  scopeDepartmentId String?
  startDate         DateTime
  endDate           DateTime
  closedAt          DateTime?

  createdById String
  createdBy   User   @relation("AuditCreatedBy", fields: [createdById], references: [id])

  auditors AuditCycleAuditor[]
  items    AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model AuditCycleAuditor {
  id String @id @default(cuid())

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  auditorId String
  auditor   User   @relation(fields: [auditorId], references: [id])

  @@unique([auditCycleId, auditorId])
  @@index([auditorId])
}

model AuditItem {
  id                 String             @id @default(cuid())
  expectedLocation   String? // "Expected location" column on Screen 8 (Asset Audit)
  verificationStatus VerificationStatus @default(PENDING)
  notes              String?
  verifiedAt         DateTime?

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  verifiedById String?
  verifiedBy   User?   @relation("AuditVerifiedBy", fields: [verifiedById], references: [id])

  // "Each asset verified only once per audit cycle" — business invariant
  @@unique([auditCycleId, assetId])
  @@index([assetId])
}

// ----------------------------------------------------------------------------
// NOTIFICATION
// ----------------------------------------------------------------------------

model Notification {
  id                String           @id @default(cuid())
  type              NotificationType
  message           String
  relatedEntityType String
  relatedEntityId   String
  isRead            Boolean          @default(false)

  recipientId String
  recipient   User   @relation(fields: [recipientId], references: [id])

  createdAt DateTime @default(now())

  // Dedup key — prevents duplicate notifications for the same event/recipient.
  @@unique([type, relatedEntityId, recipientId])
  @@index([recipientId, isRead, createdAt])
}

// ----------------------------------------------------------------------------
// ACTIVITY LOG — append-only, never modified
// ----------------------------------------------------------------------------

model ActivityLog {
  id         String   @id @default(cuid())
  action     String // e.g. ASSET_ALLOCATED, STATUS_CHANGED, ROLE_CHANGED
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([entityType, entityId])
}
