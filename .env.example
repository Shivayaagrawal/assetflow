# Password for Docker Postgres (must match DATABASE_URL credentials)
POSTGRES_PASSWORD=change_me_locally

# Local Docker PostgreSQL (host port 5433 → container 5432)
DATABASE_URL="postgresql://assetflow:change_me_locally@localhost:5433/assetflow?schema=public&connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://assetflow:change_me_locally@localhost:5433/assetflow?schema=public"

# Better Auth — generate: openssl rand -base64 32
BETTER_AUTH_SECRET="run: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# OAuth (optional) — register redirect URIs:
#   Google:  {BETTER_AUTH_URL}/api/auth/callback/google
#   GitHub:  {BETTER_AUTH_URL}/api/auth/callback/github
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Cron route protection — generate: openssl rand -hex 16
CRON_SECRET="run: openssl rand -hex 16"
