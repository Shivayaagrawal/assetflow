# Local Docker PostgreSQL — matches docker-compose.yml (host 5433 → container 5432)
POSTGRES_PASSWORD=assetflow_dev
DATABASE_URL="postgresql://assetflow:assetflow_dev@localhost:5433/assetflow?schema=public&connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://assetflow:assetflow_dev@localhost:5433/assetflow?schema=public"

# Better Auth — replace in production: openssl rand -base64 32
BETTER_AUTH_SECRET="local_dev_secret_change_in_production_32chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# OAuth (optional) — register redirect URIs:
#   Google:  {BETTER_AUTH_URL}/api/auth/callback/google
#   GitHub:  {BETTER_AUTH_URL}/api/auth/callback/github
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Cron route protection — replace in production: openssl rand -hex 16
CRON_SECRET="local_dev_cron_secret"

# Seed script default password for demo accounts
SEED_PASSWORD="Password123!"
